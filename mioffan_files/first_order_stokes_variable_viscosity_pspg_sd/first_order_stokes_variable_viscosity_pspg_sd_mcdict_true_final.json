                "5",
                "6",
                "9"
            ],
            "substitutions_dict": "",
            "symbolic_code": "term1 = dot_prod(sigma*u,v)\nterm2 = double_contract(2*nu*symgrad(u),symgrad(v))\nterm3 = p*div(v)\nterm4 = dot_prod(v,f)\nterm5 = q*div(u)\n\nstab_term_aux1 = delta*grad(q)\nstab_term_aux2 = grad(p)+sigma*u\nstab_term_aux3 = 2*matrix_vector_prod(symgrad(u),grad(nu))\nstab_term = dot_prod(stab_term_aux1,stab_term_aux2-stab_term_aux3-f)\n\nfunctional_element_rhs = term1+term2-term3-term4+term5+stab_term\n"
        },
