        "formula_7": {
            "ast": "{\"op\":\"assignment\",\"args\":[\"term1\",{\"op\":\"dot_prod\",\"args\":[{\"op\":\"mult\",\"args\":[\"sigma\",\"u\"]},\"v\"]}]}\n{\"op\":\"assignment\",\"args\":[\"term2\",{\"op\":\"double_contract\",\"args\":[{\"op\":\"mult\",\"args\":[{\"op\":\"mult\",\"args\":[2,\"nu\"]},{\"op\":\"symgrad\",\"args\":[\"u\"]}]},{\"op\":\"symgrad\",\"args\":[\"v\"]}]}]}\n{\"op\":\"assignment\",\"args\":[\"term3\",{\"op\":\"mult\",\"args\":[\"p\",{\"op\":\"div\",\"args\":[\"v\"]}]}]}\n{\"op\":\"assignment\",\"args\":[\"term4\",{\"op\":\"dot_prod\",\"args\":[\"v\",\"f\"]}]}\n{\"op\":\"assignment\",\"args\":[\"term5\",{\"op\":\"mult\",\"args\":[\"q\",{\"op\":\"div\",\"args\":[\"u\"]}]}]}\n{\"op\":\"assignment\",\"args\":[\"stab_term_aux1\",{\"op\":\"mult\",\"args\":[\"delta\",{\"op\":\"grad\",\"args\":[\"q\"]}]}]}\n{\"op\":\"assignment\",\"args\":[\"stab_term_aux2\",{\"op\":\"add\",\"args\":[{\"op\":\"grad\",\"args\":[\"p\"]},{\"op\":\"mult\",\"args\":[\"sigma\",\"u\"]}]}]}\n{\"op\":\"assignment\",\"args\":[\"stab_term_aux3\",{\"op\":\"mult\",\"args\":[2,{\"op\":\"matrix_vector_prod\",\"args\":[{\"op\":\"symgrad\",\"args\":[\"u\"]},{\"op\":\"grad\",\"args\":[\"nu\"]}]}]}]}\n{\"op\":\"assignment\",\"args\":[\"stab_term\",{\"op\":\"dot_prod\",\"args\":[\"stab_term_aux1\",{\"op\":\"subtract\",\"args\":[{\"op\":\"subtract\",\"args\":[\"stab_term_aux2\",\"stab_term_aux3\"]},\"f\"]}]}]}\n{\"op\":\"assignment\",\"args\":[\"functional_element_rhs\",{\"op\":\"add\",\"args\":[{\"op\":\"add\",\"args\":[{\"op\":\"subtract\",\"args\":[{\"op\":\"subtract\",\"args\":[{\"op\":\"add\",\"args\":[\"term1\",\"term2\"]},\"term3\"]},\"term4\"]},\"term5\"]},\"stab_term\"]}]}",
            "ast_variables": [
                "0",
                "1",
                "2",
                "3",
