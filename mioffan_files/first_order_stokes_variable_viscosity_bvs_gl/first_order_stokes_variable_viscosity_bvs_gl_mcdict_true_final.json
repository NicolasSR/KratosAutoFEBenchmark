2\",{\"op\":\"subtract\",\"args\":[{\"op\":\"add\",\"args\":[\"term6\",\"term7\"]},\"term8\"]}]}\n{\"op\":\"assignment\",\"args\":[\"functional_element_rhs\",{\"op\":\"add\",\"args\":[\"func1\",\"func2\"]}]}\n{\"op\":\"assignment\",\"args\":[\"functional_condition_rhs\",{\"op\":\"mult\",\"args\":[\"delta\",{\"op\":\"inner_prod\",\"args\":[{\"op\":\"cross_prod\",\"args\":[{\"op\":\"grad\",\"args\":[\"q\"]},\"n\"]},{\"op\":\"mult\",\"args\":[\"nu\",{\"op\":\"curl\",\"args\":[\"u\"]}]}]}]}]}",
